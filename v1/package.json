    "capture:blave:taker_intensity:overview": "node ./src/blave_capture.mjs --task blave:taker_intensity:overview --noManual --waitMs 60000",
    "capture:blave:whale_hunter:overview": "node ./src/blave_capture.mjs --task blave:whale_hunter:overview --noManual --waitMs 60000",
    "capture:blave:holder_concentration:overview": "node ./src/blave_capture.mjs --task blave:holder_concentration:overview --noManual --waitMs 60000",
    "capture:blave:market_sentiment:overview": "node ./src/blave_capture.mjs --task blave:market_sentiment:overview --noManual --waitMs 60000",
    "capture:blave:funding_rate:overview": "node ./src/blave_capture.mjs --task blave:funding_rate:overview --noManual --waitMs 60000",
    "capture:blave:funding_rate:history": "node ./src/blave_capture.mjs --task blave:funding_rate:history --noManual --waitMs 60000",
    "capture:blave:oi_imbalance:overview": "node ./src/blave_capture.mjs --task blave:oi_imbalance:overview --noManual --waitMs 60000",
    "capture:blave:squeeze_momentum:history": "node ./src/blave_capture.mjs --task blave:squeeze_momentum:history --noManual --waitMs 60000"
